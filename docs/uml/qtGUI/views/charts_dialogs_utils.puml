@startuml charts_dialogs_utils
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam packageStyle rectangle

package gui.charts {
  class ClusterScatterChart {
    - result: ClusteringResult
    - data: Data
    - clusterSet: ClusterSet
    - xAttributeIndex: int
    - yAttributeIndex: int
    - convexHullMode: boolean
    --
    + ClusterScatterChart(result: ClusteringResult)
    + setAxes(xIndex: int, yIndex: int): void
    + setConvexHullMode(enabled: boolean): void
    + createChart(): XYChart
    + saveAsPNG(file: File, width: int, height: int): void
    - addClusterSeries(chart: XYChart, cluster: Cluster, index: int): void
    - addConvexHullSeries(chart: XYChart, cluster: Cluster, index: int): void
    - addCentroidsSeries(chart: XYChart, clusters: List<Cluster>): void
    - getNumericValue(item: Item): double
  }

  class ChartViewer {
    - result: ClusteringResult
    - chartManager: ClusterScatterChart
    - stage: Stage
    - xAxisComboBox: ComboBox<String>
    - yAxisComboBox: ComboBox<String>
    - chartNode: SwingNode
    --
    + ChartViewer(result: ClusteringResult)
    + show(): void
    - createTopPanel(): VBox
    - createBottomPanel(): HBox
    - updateChart(): void
    - onAxisChanged(): void
    - handleExport(): void
    - handleExportHD(): void
  }

  class ConvexHullCalculator << NEW >> {
    --
    + {static} grahamScan(points: List<Point2D>): List<Point2D>
    - {static} findLowestPoint(points: List<Point2D>): Point2D
    - {static} ccw(p1: Point2D, p2: Point2D, p3: Point2D): double
  }
}

package gui.dialogs {
  class AboutDialog {
    - version: String
