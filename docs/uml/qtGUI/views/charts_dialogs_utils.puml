@startuml charts_dialogs_utils
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam packageStyle rectangle

package gui.charts {
  class ClusterScatterChart {
    - {static} logger: Logger
    - result: ClusteringResult
    - data: Data
    - clusterSet: ClusterSet
    - discreteMappings: Map<Integer, Map<String, Integer>>
    - xAttributeIndex: int
    - yAttributeIndex: int
    - convexHullMode: boolean
    --
    + ClusterScatterChart(result: ClusteringResult)
    + setAxes(xIndex: int, yIndex: int): void
    + setConvexHullMode(enabled: boolean): void
    + createChart(): XYChart
    + saveAsPNG(file: File): void
    + saveAsPNG(file: File, width: int, height: int): void
    + getAttributeNames(): String[]
    + getXAttributeIndex(): int
    + getYAttributeIndex(): int
    - configureStyling(chart: XYChart): void
    - addClusterSeries(chart: XYChart, cluster: Cluster, index: int): void
    - addConvexHullSeries(chart: XYChart, cluster: Cluster, index: int): void
    - addCentroidsSeries(chart: XYChart, clusters: List<Cluster>): void
    - getNumericValue(item: Item, attributeIndex: int): double
  }

  class ChartViewer {
    - {static} logger: Logger
    - result: ClusteringResult
    - chartManager: ClusterScatterChart
    - stage: Stage
    - xAxisComboBox: ComboBox<String>
    - yAxisComboBox: ComboBox<String>
    - chartNode: SwingNode
    --
    + ChartViewer(result: ClusteringResult)
    + show(): void
    + getStage(): Stage
    - initializeUI(): void
    - createTopPanel(): VBox
    - createBottomPanel(): HBox
    - onAxisChanged(): void
    - updateChart(): void
    - handleExport(): void
    - handleExportHD(): void
    - exportChart(width: int, height: int): void
    - showError(title: String, message: String): void
  }

  class ConvexHullCalculator {
    --
    + {static} grahamScan(points: List<Point2D>): List<Point2D>
    - {static} findLowestPoint(points: List<Point2D>): Point2D
    - {static} ccw(p1: Point2D, p2: Point2D, p3: Point2D): double
  }
}

package gui.dialogs {
  class AboutDialog {
    - {static} logger: Logger
    - {static} APP_NAME: String
    - {static} APP_VERSION: String
    - {static} APP_BUILD: String
    - {static} JAVA_VERSION: String
    - {static} JAVAFX_VERSION: String
    - stage: Stage
    --
    + AboutDialog()
    + show(): void
    - initializeDialog(): void
    - showInfo(title: String, message: String): void
  }

  class DatasetPreviewDialog {
    - stage: Stage
    - data: Data
    --
    + DatasetPreviewDialog(data: Data)
    + show(): void
    - setupDialog(): void
    - createHeader(): VBox
    - createDataTab(): Tab
    - createTableView(): TableView
    - createStatsTab(): Tab
    - createFooter(): HBox
  }

  class StatisticsDialog {
    - stage: Stage
    - result: ClusteringResult
    --
    + StatisticsDialog(result: ClusteringResult)
    + show(): void
    - initializeDialog(): void
    - createGeneralStatsPane(): VBox
    - createSizeDistributionChart(): BarChart
    - createDistanceDistributionChart(): BarChart
    - createClusterTable(): TableView
    - addStatsHeader(grid: GridPane, row: int, text: String): void
    - addStatsRow(grid: GridPane, row: int, label: String, value: String): void
  }
}

package gui.utils {
  class ApplicationContext << Singleton >> {
    - {static} instance: ApplicationContext
    - clusteringService: ClusteringService
    - dataImportService: DataImportService
    - exportService: ExportService
    - currentConfiguration: ClusteringConfiguration
    - currentResult: ClusteringResult
    --
    - ApplicationContext()
    + {static} getInstance(): ApplicationContext
    + getClusteringService(): ClusteringService
    + getDataImportService(): DataImportService
    + getExportService(): ExportService
    + setCurrentConfiguration(configuration: ClusteringConfiguration): void
    + getCurrentConfiguration(): ClusteringConfiguration
    + getCurrentResult(): ClusteringResult
    + setCurrentResult(result: ClusteringResult): void
    + clear(): void
  }

  class ThemeManager << Singleton >> {
    - {static} logger: Logger
    - {static} SETTINGS_FILE: String
    - {static} LIGHT_THEME_CSS: String
    - {static} DARK_THEME_CSS: String
    - {static} instance: ThemeManager
    - currentTheme: Theme
    - currentFontSize: FontSize
    - primaryScene: Scene
    - settings: Properties
    --
    - ThemeManager()
    + {static} getInstance(): ThemeManager
    + setPrimaryScene(scene: Scene): void
    + setTheme(theme: Theme): void
    + setThemeByName(themeDisplayName: String): void
    + setFontSize(fontSize: FontSize): void
    + setFontSizeByName(fontSizeDisplayName: String): void
    + getCurrentTheme(): Theme
    + getCurrentFontSize(): FontSize
    + getCurrentThemeDisplayName(): String
    + getCurrentFontSizeDisplayName(): String
    + isDarkMode(): boolean
    + toggleTheme(): void
    - applyTheme(): void
    - applyFontSize(): void
    - loadSettings(): void
    - saveSettings(): void
  }

  enum "gui.utils.ThemeManager.Theme" as Theme {
    LIGHT
    DARK
    --
    + getDisplayName(): String
    + fromDisplayName(displayName: String): Theme
  }

  enum "gui.utils.ThemeManager.FontSize" as FontSize {
    SMALL
    MEDIUM
    LARGE
    XLARGE
    --
    + getDisplayName(): String
    + getSize(): int
    + fromDisplayName(displayName: String): FontSize
  }

  class ColorPalette {
    - {static} DEFAULT_PALETTE: Color[]
    --
    - ColorPalette()
    - {static} generateColorHSB(index: int): Color
    + {static} getColor(clusterIndex: int): Color
    + {static} getColors(numClusters: int): Color[]
    + {static} toHexString(color: Color): String
    + {static} toJavaFX(awtColor: Color): javafx.scene.paint.Color
    + {static} getDefaultPaletteSize(): int
    + {static} getColorWithAlpha(clusterIndex: int, alpha: int): Color
  }

  class Point2D {
    - x: double
    - y: double
    --
    + Point2D(x: double, y: double)
    + getX(): double
    + getY(): double
    + distanceTo(other: Point2D): double
    + polarAngleFrom(pivot: Point2D): double
    + toString(): String
    + equals(obj: Object): boolean
    + hashCode(): int
  }

  class DatasetLoader {
    --
    - DatasetLoader()
    + {static} loadIrisDataset(): Data
    + {static} getAvailableDatasets(): String[]
  }
}

' ===== Relazioni =====
ChartViewer *-- "1" ClusterScatterChart : chartManager
ChartViewer ..> "org.knowm.xchart.XYChart" : <<uses>>

ClusterScatterChart ..> ConvexHullCalculator : <<uses>>
ClusterScatterChart ..> ColorPalette : <<uses>>
ConvexHullCalculator ..> Point2D : <<uses>>

ThemeManager o-- "1" Theme : currentTheme
ThemeManager ..> FontSize : <<uses>>
DatasetLoader ..> "data.Data" : <<creates>>

@enduml
